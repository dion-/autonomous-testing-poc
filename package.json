{
  "name": "fuzzy-testing-poc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "lint:ci": "oxlint --format=github --deny-warnings",
    "format": "oxfmt --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:bombadil": "pnpm exec vite preview --port 4173 --host & npx wait-on http://localhost:4173 && bombadil test http://localhost:4173 --no-sandbox --exit-on-violation --time-limit 2m --output-path ./bombadil-results",
    "ci:local": "npx @redwoodjs/agent-ci run --all --var BOMBADIL_TIME_LIMIT=2m"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "cpu-features",
      "protobufjs",
      "ssh2"
    ]
  },
  "devDependencies": {
    "@antithesishq/bombadil": "^0.4.5",
    "@redwoodjs/agent-ci": "^0.15.0",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  }
}
