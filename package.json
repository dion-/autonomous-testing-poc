{
  "name": "fuzzy-testing-poc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "lint:ci": "oxlint --format=github --deny-warnings",
    "typecheck": "tsc --noEmit",
    "test:bombadil": "vite preview --port 4173 --host & wait-on http://localhost:4173 && bombadil test http://localhost:4173 --no-sandbox --exit-on-violation --time-limit 2m --output-path ./bombadil-results"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@antithesishq/bombadil": "^0.4.5",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "oxlint": "^1.62.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  }
}
